# ============================================================
# Come Color With Me — Docker / Directus Environment Variables
# Copy this file to .env.docker and fill in real values.
# Never commit .env.docker
# ============================================================

# Directus encryption keys — generate with: openssl rand -hex 32
KEY=replace-with-random-32-char-string
SECRET=replace-with-random-32-char-string

# Directus admin credentials
ADMIN_EMAIL=admin@comecolorwith.me
ADMIN_PASSWORD=change-this-local-dev-password

# PostgreSQL password (shared between postgres + directus containers)
DB_PASSWORD=local-dev-db-password

# Directus public URL (used in emails and asset URLs)
DIRECTUS_PUBLIC_URL=http://localhost:8055

# Static API token for backend → Directus communication
# Generate in Directus admin: Settings → API Tokens
DIRECTUS_ADMIN_TOKEN=generate-after-first-boot
