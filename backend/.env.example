# ============================================================
# Come Color With Me — Backend Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env
# ============================================================

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://ccwm:password@localhost:5432/ccwm_local

# Directus CMS
DIRECTUS_URL=http://localhost:8055
DIRECTUS_ADMIN_TOKEN=

# Auth (Supabase — confirmed)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=change-this-in-production

# Storage
STORAGE_PROVIDER=local
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Feature flags
ENABLE_PREMIUM_PRINTS=false
ENABLE_COLORING_CLUB=false
ENABLE_ACCOUNT_DOWNLOADS=true
ENABLE_NEWSLETTER=true
ENABLE_WATERMARKS=true
ENABLE_CART=false
ENABLE_CHECKOUT=false
ENABLE_ARTIST_UPLOADS=false
ENABLE_GAMIFICATION=false
ENABLE_THEME_PLAYFUL=false
ENABLE_THEME_WHIMSICAL=true
