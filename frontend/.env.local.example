# ============================================================
# Come Color With Me — Frontend Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local
# ============================================================

# API
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055

# Auth (Supabase — confirmed)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Analytics
NEXT_PUBLIC_ANALYTICS_ID=
NEXT_PUBLIC_ANALYTICS_ENABLED=false

# Newsletter
NEWSLETTER_API_KEY=
NEWSLETTER_LIST_ID=

# Feature flag defaults (JSON — overridden by /api/settings at runtime)
NEXT_PUBLIC_DEFAULT_FLAGS={"ENABLE_PREMIUM_PRINTS":false,"ENABLE_COLORING_CLUB":false,"ENABLE_ACCOUNT_DOWNLOADS":true,"ENABLE_NEWSLETTER":true,"ENABLE_WATERMARKS":true,"ENABLE_CART":false,"ENABLE_CHECKOUT":false,"ENABLE_ARTIST_UPLOADS":false,"ENABLE_GAMIFICATION":false,"ENABLE_THEME_PLAYFUL":false,"ENABLE_THEME_WHIMSICAL":true}
